# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=HorizonExoplanet
APP_ENV=development          # development | production | demo
DEBUG=true
SECRET_KEY=change-me-in-production-32-chars-min

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://horizon:horizon@localhost:5432/horizondb
# Fallback to SQLite when PostgreSQL unavailable (set USE_SQLITE=true)
USE_SQLITE=false
SQLITE_URL=sqlite+aiosqlite:///./horizon.db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
USE_REDIS=true

# ── MAST / Lightkurve ────────────────────────────────────────────────────────
MAST_TIMEOUT=120
MAST_CACHE_DIR=./backend/datasets/cache

# ── ML Models ────────────────────────────────────────────────────────────────
MODEL_DIR=./backend/ml_models
CNN_MODEL_PATH=./backend/ml_models/transit_classifier.h5

# ── Storage ──────────────────────────────────────────────────────────────────
DATASETS_DIR=./backend/datasets
REPORTS_DIR=./backend/reports/output
MAX_UPLOAD_SIZE_MB=500

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
